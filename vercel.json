{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",                "destination": "/web/landing.html" },
    { "source": "/admin",           "destination": "/web/admin.html" },
    { "source": "/admin.html",      "destination": "/web/admin.html" },
    { "source": "/index.html",      "destination": "/web/index.html" },
    { "source": "/category.html",   "destination": "/web/category.html" },
    { "source": "/detail.html",     "destination": "/web/detail.html" },
    { "source": "/assets/:path*",   "destination": "/web/assets/:path*" },
    { "source": "/:slug/admin",     "destination": "/web/admin.html?store=:slug" },
    { "source": "/:slug",           "destination": "/web/index.html?store=:slug" }
  ],
  "headers": [
    {
      "source": "/admin.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag",  "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/(.*)/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Robots-Tag",  "value": "noindex, nofollow" }
      ]
    }
  ]
}
