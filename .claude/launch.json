{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "skmagic-dealer",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8765", "--bind", "127.0.0.1"],
      "port": 8765
    },
    {
      "name": "skmagic-node",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path'),root=process.cwd(),web=path.join(root,'web');const m={'.html':'text/html;charset=utf-8','.js':'text/javascript;charset=utf-8','.css':'text/css;charset=utf-8','.json':'application/json;charset=utf-8','.png':'image/png','.jpg':'image/jpeg','.jpeg':'image/jpeg','.gif':'image/gif','.svg':'image/svg+xml','.woff2':'font/woff2','.woff':'font/woff','.ico':'image/x-icon'};function send(s,f){fs.readFile(f,(e,d)=>{if(e){s.statusCode=404;s.end('404')}else{s.setHeader('Content-Type',m[path.extname(f).toLowerCase()]||'application/octet-stream');s.end(d)}})}http.createServer((q,s)=>{let u=decodeURIComponent(q.url.split('?')[0]);if(u==='/')return send(s,path.join(web,'landing.html'));if(u==='/admin'||u.endsWith('/admin'))return send(s,path.join(web,'admin.html'));if(u.startsWith('/assets/'))return send(s,path.join(web,u));let f=path.join(root,u);try{if(fs.statSync(f).isFile())return send(s,f)}catch(e){}if(!path.extname(u))return send(s,path.join(web,'index.html'));s.statusCode=404;s.end('404')}).listen(8765,'127.0.0.1',()=>console.log('serving on http://127.0.0.1:8765 (Vercel-like routing)'))"],
      "port": 8765
    }
  ]
}
