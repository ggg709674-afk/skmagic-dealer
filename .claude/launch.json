{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "skmagic-dealer",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8765", "--bind", "127.0.0.1"],
      "port": 8765
    },
    {
      "name": "skmagic-node",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path'),root=process.cwd();const m={'.html':'text/html;charset=utf-8','.js':'text/javascript;charset=utf-8','.css':'text/css;charset=utf-8','.json':'application/json;charset=utf-8','.png':'image/png','.jpg':'image/jpeg','.jpeg':'image/jpeg','.gif':'image/gif','.svg':'image/svg+xml','.woff2':'font/woff2','.woff':'font/woff'};http.createServer((q,s)=>{let u=decodeURIComponent(q.url.split('?')[0]);if(u==='/')u='/web/index.html';let f=path.join(root,u);try{if(fs.statSync(f).isDirectory())f=path.join(f,'index.html')}catch(e){}fs.readFile(f,(e,d)=>{if(e){s.statusCode=404;s.end('404')}else{s.setHeader('Content-Type',m[path.extname(f).toLowerCase()]||'application/octet-stream');s.end(d)}})}).listen(8765,'127.0.0.1',()=>console.log('serving '+root+' on http://127.0.0.1:8765'))"],
      "port": 8765
    }
  ]
}
